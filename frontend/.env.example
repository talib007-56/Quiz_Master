# ===========================================
# Quiz Master Frontend - Environment Configuration
# ===========================================

# ===========================================
# API CONFIGURATION
# ===========================================
VITE_API_URL=http://localhost:5001/api

# ===========================================
# APPLICATION SETTINGS
# ===========================================
VITE_APP_NAME=Quiz Master
VITE_APP_VERSION=1.0.0
VITE_ENABLE_ANALYTICS=false

# ===========================================
# QUIZ SETTINGS
# ===========================================
VITE_MAX_QUIZ_TIME=3600
VITE_DEFAULT_QUIZ_TIME=1800
VITE_PAGINATION_SIZE=10
VITE_MAX_QUESTIONS_PER_PAGE=5

# ===========================================
# UI SETTINGS
# ===========================================
VITE_THEME=light
VITE_ENABLE_DARK_MODE=true
VITE_ANIMATION_DURATION=300

# ===========================================
# PERFORMANCE SETTINGS
# ===========================================
VITE_ENABLE_LAZY_LOADING=true
VITE_CACHE_DURATION=300000
VITE_DEBOUNCE_DELAY=300
